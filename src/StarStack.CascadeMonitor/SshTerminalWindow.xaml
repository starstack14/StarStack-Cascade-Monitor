<Window x:Class="StarStack.CascadeMonitor.SshTerminalWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="SSH-терминал · NX31" Height="620" Width="920" Background="#0C080D" Foreground="#FFF5F1" WindowStartupLocation="CenterOwner">
    <Grid Margin="14"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,10"><TextBlock Text="SSH · root@192.168.11.1" FontSize="15" Foreground="#75D8FF"/><TextBlock x:Name="StatusText" DockPanel.Dock="Right" Text="CONNECTING" Foreground="#FFAD5C"/></DockPanel>
        <TextBox x:Name="OutputBox" Grid.Row="1" Background="#09070A" Foreground="#D6F7DF" BorderBrush="#4B2833" FontFamily="Cascadia Mono" FontSize="12" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
        <DockPanel Grid.Row="2" Margin="0,10,0,0"><TextBox x:Name="CommandBox" Height="32" Background="#21131B" Foreground="#FFF5F1" BorderBrush="#4B2833" FontFamily="Cascadia Mono" VerticalContentAlignment="Center" KeyDown="CommandBox_KeyDown"/><Button Content="Отправить" Width="100" Margin="8,0,0,0" Click="Send_Click"/><Button Content="Отключить" Width="100" Margin="8,0,0,0" Click="Close_Click"/></DockPanel>
    </Grid>
</Window>
