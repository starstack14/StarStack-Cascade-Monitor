<Window x:Class="StarStack.CascadeMonitor.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="StarStack Cascade Monitor" Height="720" Width="1120" MinHeight="560" MinWidth="900" Background="#0C080D" Foreground="#FFF5F1" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="FontFamily" Value="Segoe UI"/></Style>
        <Style x:Key="Card" TargetType="Border"><Setter Property="Background" Value="#21131B"/><Setter Property="BorderBrush" Value="#4B2833"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="18"/></Style>
        <Style x:Key="ActionButton" TargetType="Button"><Setter Property="Foreground" Value="#75D8FF"/><Setter Property="Background" Value="#2B1722"/><Setter Property="BorderBrush" Value="#4B2833"/><Setter Property="Padding" Value="14,8"/><Setter Property="Margin" Value="0,0,8,0"/></Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,22"><StackPanel DockPanel.Dock="Left"><TextBlock Text="StarStack" FontSize="22" FontWeight="SemiBold"/><TextBlock Text="NEON CASCADE MONITOR / .NET WPF" Foreground="#AE8E96" FontSize="11" Margin="0,4,0,0"/></StackPanel><StackPanel DockPanel.Dock="Right"><TextBlock x:Name="CascadeStatusText" Text="CASCADE CHECKING" Foreground="#FFAD5C" FontSize="14" HorizontalAlignment="Right"/><TextBlock Text="Profile: Home" Foreground="#AE8E96" FontSize="11" HorizontalAlignment="Right" Margin="0,4,0,0"/></StackPanel></DockPanel>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,18"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock x:Name="RouterStatusText" Grid.Column="0" Text="NX31 CHECKING" Foreground="#FFAD5C" FontSize="14" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="-&gt;" Foreground="#FFAD5C" FontSize="18" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="Moscow" FontSize="14" HorizontalAlignment="Center"/><TextBlock Grid.Column="3" Text="-&gt;" Foreground="#FFAD5C" FontSize="18" HorizontalAlignment="Center"/><TextBlock Grid.Column="4" Text="Germany" FontSize="14" HorizontalAlignment="Center"/></Grid></Border>
        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,9,0"><StackPanel><DockPanel><TextBlock Text="Moscow" FontSize="18" FontWeight="SemiBold"/><TextBlock x:Name="MoscowStatusText" DockPanel.Dock="Right" Text="ONLINE" Foreground="#62E6A7" FontSize="12"/></DockPanel><TextBlock Text="VLESS / Reality / TCP" Foreground="#75D8FF" Margin="0,12,0,0"/><TextBlock x:Name="MoscowMetricsText" Text="Latency -- / Load -- / RAM --" Foreground="#AE8E96" Margin="0,18,0,0"/><ProgressBar x:Name="MoscowLoadBar" Value="0" Height="5" Margin="0,16,0,0" Foreground="#62E6A7" Background="#150C12"/></StackPanel></Border>
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="9,0,0,0"><StackPanel><DockPanel><TextBlock Text="Germany" FontSize="18" FontWeight="SemiBold"/><TextBlock x:Name="GermanyStatusText" DockPanel.Dock="Right" Text="ONLINE" Foreground="#62E6A7" FontSize="12"/></DockPanel><TextBlock Text="VLESS / XHTTP / Reality" Foreground="#75D8FF" Margin="0,12,0,0"/><TextBlock x:Name="GermanyMetricsText" Text="API status / Load -- / RAM --" Foreground="#AE8E96" Margin="0,18,0,0"/><ProgressBar x:Name="GermanyLoadBar" Value="0" Height="5" Margin="0,16,0,0" Foreground="#62E6A7" Background="#150C12"/></StackPanel></Border>
        </Grid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,20,0,0"><Button Style="{StaticResource ActionButton}" Content="SSH Terminal NX31" Click="OpenEmbeddedSsh_Click"/><Button Style="{StaticResource ActionButton}" Content="Windows Terminal" Click="OpenWindowsTerminal_Click"/><Button Style="{StaticResource ActionButton}" Content="Settings" Click="Settings_Click"/><Button Style="{StaticResource ActionButton}" Content="Weekly report" Click="Report_Click"/><Button Style="{StaticResource ActionButton}" Content="Check updates" Click="Updates_Click"/><Button Style="{StaticResource ActionButton}" Content="Refresh" Click="Refresh_Click"/><TextBlock Text="Local desktop app / SSH is not exposed by web panel" Foreground="#AE8E96" VerticalAlignment="Center" Margin="12,0,0,0"/></StackPanel>
    </Grid>
</Window>
