<Window x:Class="StarStack.CascadeMonitor.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="StarStack Cascade Monitor" Height="680" Width="1040" MinHeight="560" MinWidth="820" Background="#0B0A10" Foreground="#F5F2F6" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="FontFamily" Value="Segoe UI"/></Style>
        <Style x:Key="GlassCard" TargetType="Border"><Setter Property="Background" Value="#241721"/><Setter Property="BorderBrush" Value="#563448"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="14"/><Setter Property="Padding" Value="18"/></Style>
        <Style x:Key="ActionButton" TargetType="Button"><Setter Property="Foreground" Value="#DCC9D5"/><Setter Property="Background" Value="#34202F"/><Setter Property="BorderBrush" Value="#63364D"/><Setter Property="Padding" Value="12,7"/><Setter Property="Margin" Value="0,0,8,0"/></Style>
        <Style x:Key="TabStyle" TargetType="TabItem"><Setter Property="Padding" Value="18,9"/><Setter Property="Foreground" Value="#CDB7C5"/></Style>
    </Window.Resources>
    <Grid Margin="22">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,14"><StackPanel Orientation="Horizontal"><TextBlock Text="StarStack" FontSize="22" FontWeight="SemiBold"/><TextBlock Text="  /  CASCADE MONITOR" Foreground="#9C8190" VerticalAlignment="Bottom" Margin="8,0,0,4" FontSize="11"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><TextBlock x:Name="CascadeStatusText" Text="CASCADE CHECKING" Foreground="#FFB45C" FontSize="13" VerticalAlignment="Center"/><TextBlock Text="  ·  " Foreground="#765466" VerticalAlignment="Center"/><TextBlock x:Name="ProfileText" Text="Profile: Home" Foreground="#A98DA0" VerticalAlignment="Center"/><TextBlock Text="  ·  " Foreground="#765466" VerticalAlignment="Center"/><TextBlock x:Name="LastCheckText" Text="проверка..." Foreground="#A98DA0" VerticalAlignment="Center"/><Button Content="⋮" FontSize="20" Width="34" Height="32" Margin="14,0,0,0" Click="Actions_Click"/></StackPanel></Grid>
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="12" Margin="0,0,0,16"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Grid.Column="0" Background="#321B2B" CornerRadius="9" Padding="14,10"><StackPanel><TextBlock Text="NX31" HorizontalAlignment="Center" FontWeight="SemiBold"/><TextBlock x:Name="RouterStatusText" Text="CHECKING" HorizontalAlignment="Center" Foreground="#FFB45C" FontSize="11" Margin="0,4,0,0"/></StackPanel></Border><TextBlock Grid.Column="1" Text="→" Foreground="#FFB45C" FontSize="22" VerticalAlignment="Center" Margin="14,0"/><Border Grid.Column="2" Background="#321B2B" CornerRadius="9" Padding="14,10"><StackPanel><TextBlock Text="Moscow" HorizontalAlignment="Center" FontWeight="SemiBold"/><TextBlock x:Name="MoscowStatusText" Text="CHECK" HorizontalAlignment="Center" Foreground="#FFB45C" FontSize="11" Margin="0,4,0,0"/></StackPanel></Border><TextBlock Grid.Column="3" Text="→" Foreground="#FFB45C" FontSize="22" VerticalAlignment="Center" Margin="14,0"/><Border Grid.Column="4" Background="#321B2B" CornerRadius="9" Padding="14,10"><StackPanel><TextBlock Text="Germany" HorizontalAlignment="Center" FontWeight="SemiBold"/><TextBlock x:Name="GermanyStatusText" Text="CHECK" HorizontalAlignment="Center" Foreground="#FFB45C" FontSize="11" Margin="0,4,0,0"/></StackPanel></Border></Grid></Border>
        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0"><TabItem x:Name="OverviewTab" Header="Обзор" Style="{StaticResource TabStyle}"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="0,14,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,8,0"><StackPanel><DockPanel><TextBlock Text="🇷🇺  Moscow" FontSize="19" FontWeight="SemiBold"/><TextBlock x:Name="MoscowOnlineLabel" Text="ONLINE" DockPanel.Dock="Right" Foreground="#62E6A7"/></DockPanel><TextBlock Text="VLESS / Reality / TCP" Foreground="#75D8FF" Margin="0,10,0,0"/><TextBlock x:Name="MoscowMetricsText" Text="Load -- / RAM -- / Users --" Foreground="#C6AAB8" Margin="0,16,0,0"/><ProgressBar x:Name="MoscowLoadBar" Value="0" Height="5" Margin="0,14,0,0" Foreground="#62E6A7" Background="#160D15"/></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource GlassCard}" Margin="8,0,0,0"><StackPanel><DockPanel><TextBlock Text="🇩🇪  Germany" FontSize="19" FontWeight="SemiBold"/><TextBlock x:Name="GermanyOnlineLabel" Text="ONLINE" DockPanel.Dock="Right" Foreground="#62E6A7"/></DockPanel><TextBlock Text="VLESS / XHTTP / Reality" Foreground="#75D8FF" Margin="0,10,0,0"/><TextBlock x:Name="GermanyMetricsText" Text="Load -- / RAM -- / Users --" Foreground="#C6AAB8" Margin="0,16,0,0"/><ProgressBar x:Name="GermanyLoadBar" Value="0" Height="5" Margin="0,14,0,0" Foreground="#62E6A7" Background="#160D15"/></StackPanel></Border></Grid><Border Style="{StaticResource GlassCard}" Margin="0,16,0,0"><StackPanel><TextBlock x:Name="DiagnosisText" Text="Диагностика: проверка..." Foreground="#FFB45C"/><TextBlock x:Name="RouterMetricsText" Text="NX31 · uptime -- · Load -- · RAM --" Foreground="#A98DA0" Margin="0,8,0,0"/></StackPanel></Border></StackPanel></ScrollViewer></TabItem>
            <TabItem x:Name="GraphsTab" Header="Графики" Style="{StaticResource TabStyle}"><StackPanel Margin="0,14,0,0"><TextBlock Text="Load и RAM за последние измерения" FontSize="17" Margin="0,0,0,12"/><Border Style="{StaticResource GlassCard}"><Canvas x:Name="MiniChart" Height="330" Background="#160D15"/></Border><TextBlock Text="Для подробной истории откройте недельный отчёт через меню ⋮" Foreground="#A98DA0" Margin="0,10,0,0"/></StackPanel></TabItem>
            <TabItem x:Name="UsersTab" Header="Пользователи" Style="{StaticResource TabStyle}"><StackPanel Margin="0,14,0,0"><TextBlock Text="Подключённые пользователи и устройства" FontSize="17"/><TextBlock x:Name="UsersSummaryText" Text="Данные загружаются..." Foreground="#A98DA0" Margin="0,12,0,0"/><ListBox x:Name="UsersList" Margin="0,12,0,0" Background="#241721" BorderBrush="#563448"/></StackPanel></TabItem>
            <TabItem x:Name="DiagnosticsTab" Header="Диагностика" Style="{StaticResource TabStyle}"><StackPanel Margin="0,14,0,0"><TextBlock Text="Проверки и действия" FontSize="17"/><TextBlock x:Name="TlsStatusText" Text="TLS: не проверен" Foreground="#A98DA0" Margin="0,12,0,0"/><WrapPanel Margin="0,16,0,0"><Button Style="{StaticResource ActionButton}" Content="Speed test" Click="SpeedTest_Click"/><Button Style="{StaticResource ActionButton}" Content="Проверить TLS" Click="Tls_Click"/><Button Style="{StaticResource ActionButton}" Content="SSH Terminal" Click="OpenEmbeddedSsh_Click"/></WrapPanel></StackPanel></TabItem>
            <TabItem x:Name="SettingsTab" Header="Настройки" Style="{StaticResource TabStyle}"><StackPanel Margin="0,14,0,0"><TextBlock Text="Параметры приложения" FontSize="17"/><TextBlock Text="Адреса, токен, язык, профиль и режим виджета" Foreground="#A98DA0" Margin="0,10,0,0"/><Button Style="{StaticResource ActionButton}" Content="Открыть настройки" Click="Settings_Click" Margin="0,18,0,0" HorizontalAlignment="Left"/></StackPanel></TabItem>
        </TabControl>
    </Grid>
</Window>
